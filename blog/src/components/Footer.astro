---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<span>© {today.getFullYear()} Paulo Carvalho · <a href="https://github.com/PauloCarv/drupalclaw-project" target="_blank" rel="noopener noreferrer">DrupalClaw</a> is open source</span>
		<div class="links">
			<a href="https://github.com/PauloCarv/drupalclaw-project" target="_blank" rel="noopener noreferrer">GitHub</a>
			<a href="/rss.xml">RSS</a>
		</div>
	</div>
</footer>

<style>
	footer {
		margin-top: 4em;
		padding: 1.5em;
		background: #0a0e1a;
		border-top: 1px solid #1a2035;
		color: #4a5980;
		font-size: 0.85em;
	}
	.footer-inner {
		max-width: 760px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.75em;
	}
	a {
		color: #4a5980;
		text-decoration: none;
		transition: color 0.2s;
	}
	a:hover { color: #2dd4bf; }
	.links {
		display: flex;
		gap: 1.25em;
	}
</style>
