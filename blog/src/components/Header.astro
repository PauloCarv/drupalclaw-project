---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="site-title">
			<span class="claw">🐾</span>
			DrupalClaw
		</a>
		<div class="links">
			<HeaderLink href="/blog">Blog</HeaderLink>
			<a href="https://github.com/PauloCarv/drupalclaw-project" target="_blank" rel="noopener noreferrer" class="nav-link">
				GitHub
			</a>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1.5em;
		background: #0a0e1a;
		border-bottom: 1px solid #1a2035;
	}
	nav {
		max-width: 760px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 52px;
	}
	.site-title {
		display: flex;
		align-items: center;
		gap: 0.4em;
		font-weight: 700;
		font-size: 1em;
		color: #fff;
		text-decoration: none;
	}
	.site-title:hover { color: #2dd4bf; }
	.links {
		display: flex;
		align-items: center;
		gap: 0.25em;
	}
	.nav-link {
		padding: 0.4em 0.75em;
		color: #8899b8;
		text-decoration: none;
		font-size: 0.9em;
		border-radius: 4px;
		transition: color 0.2s;
	}
	.nav-link:hover { color: #fff; }
</style>
