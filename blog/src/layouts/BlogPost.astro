---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />

		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<Image src={heroImage} alt="" width={1020} height={400} />
					</div>
				)}

				<div class="prose">
					<header class="post-header">
						<div class="post-meta">
							<span class="post-date"><FormattedDate date={pubDate} /></span>
							{updatedDate && (
								<span class="post-updated">Updated <FormattedDate date={updatedDate} /></span>
							)}
						</div>
						<h1>{title}</h1>
						{description && <p class="post-description">{description}</p>}
						<div class="post-divider"></div>
					</header>

					<div class="post-content">
						<slot />
					</div>
				</div>
			</article>

			<nav class="post-nav">
				<a href="/blog" class="back-link">← All articles</a>
			</nav>
		</main>

		<Footer />
	</body>
</html>

<style>
	main {
		width: 1100px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
		padding: 3em 1em 5em;
	}

	.hero-image {
		width: calc(100% + 2em);
		margin: -3em -1em 2.5em;
		overflow: hidden;
		border-radius: 0 0 12px 12px;
	}
	.hero-image img {
		width: 100%;
		max-height: 380px;
		object-fit: cover;
		border-radius: 0;
		display: block;
	}

	.prose {
		max-width: 860px;
		margin: 0 auto;
	}

	.post-header {
		margin-bottom: 2.5em;
	}

	.post-meta {
		display: flex;
		align-items: center;
		gap: 1em;
		margin-bottom: 1em;
	}

	.post-date {
		font-size: 0.82em;
		color: #2dd4bf;
		font-weight: 500;
		letter-spacing: 0.03em;
	}

	.post-updated {
		font-size: 0.78em;
		color: #4a5980;
		font-style: italic;
	}

	.post-header h1 {
		font-size: 2.25em;
		line-height: 1.2;
		color: #fff;
		margin: 0 0 0.6em;
		letter-spacing: -0.02em;
	}

	.post-description {
		font-size: 1.05em;
		color: #8899b8;
		margin: 0 0 1.5em;
		line-height: 1.6;
	}

	.post-divider {
		height: 1px;
		background: linear-gradient(to right, #0678be, #1a2035 60%);
		margin-top: 0.5em;
	}

	.post-content {
		font-size: 1.12em;
		line-height: 1.8;
		color: #c8d4e8;
		text-align: justify;
		hyphens: auto;
	}

	.post-content :global(h2) {
		font-size: 1.5em;
		color: #fff;
		margin: 2em 0 0.75em;
		padding-top: 1em;
		border-top: 1px solid #1a2035;
	}

	.post-content :global(h3) {
		font-size: 1.2em;
		color: #e2e8f4;
		margin: 1.5em 0 0.5em;
	}

	.post-content :global(a) {
		color: #0e90d9;
		text-decoration: underline;
		text-decoration-color: rgba(14,144,217,0.3);
		text-underline-offset: 3px;
	}
	.post-content :global(a:hover) {
		color: #2dd4bf;
		text-decoration-color: rgba(45,212,191,0.5);
	}

	.post-content :global(ul),
	.post-content :global(ol) {
		padding-left: 1.5em;
		margin-bottom: 1.5em;
	}

	.post-content :global(li) {
		margin-bottom: 0.4em;
	}

	.post-content :global(img) {
		width: 100%;
		border-radius: 10px;
		border: 1px solid #1a2035;
		margin: 1.5em 0;
	}

	.post-nav {
		margin-top: 3em;
		padding-top: 1.5em;
		border-top: 1px solid #1a2035;
	}

	.back-link {
		font-size: 0.88em;
		color: #4a5980;
		transition: color 0.15s;
	}
	.back-link:hover { color: #8899b8; }

	@media (max-width: 720px) {
		.post-header h1 { font-size: 1.75em; }
		.hero-image { margin: -2em -1em 2em; }
		.post-content { font-size: 1em; }
	}
</style>
